{
  "name": "coffee-rolodex",
  "version": "1.0.0",
  "description": "Local-first desktop app for tracking espresso coffee bags",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "npm run build && electron-builder",
    "package:linux-arm64": "npm run build && electron-builder --linux --arm64",
    "package:linux-armv7l": "npm run build && electron-builder --linux --armv7l",
    "setup": "node node_modules/electron/install.js && electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "test": "vitest run --project renderer",
    "test:watch": "vitest --project renderer",
    "test:db": "vitest run --project main",
    "test:all": "vitest run",
    "test:coverage": "vitest run --project renderer --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.5",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.4.5",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.19",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "jsdom": "^27.0.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "vite": "^5.4.21",
    "vitest": "^3.2.4"
  }
}
